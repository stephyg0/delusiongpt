{
  "name": "delusiongpt",
  "version": "0.1.0",
  "description": "A calm, emotionally supportive, increasingly delusional terminal companion for stressed developers.",
  "type": "module",
  "bin": {
    "delusiongpt": "dist/index.js"
  },
  "files": [
